# Server
ENVIRONMENT=development
PORT=8080
VERSION=0.1.0

# Database
DATABASE_URL=postgres://compile:compile_dev_password@localhost:5432/compile?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=compile-dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=compile-dev-refresh-secret-change-in-production
JWT_EXPIRATION_HOURS=24

# Rate Limiting
RATE_LIMIT=100

# ML Worker
ML_SERVICE_URL=http://localhost:8000

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AWS (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=compile-models

# WebAuthn
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:3000
WEBAUTHN_RP_NAME=Compile

# OpenAI (for behavior classification + architecture recommendation)
OPENAI_API_KEY=
OPENAI_ORG_ID=

# FlyWire Data (for ML worker)
# COMPILE_DATA_DIR=/path/to/flywire/data
